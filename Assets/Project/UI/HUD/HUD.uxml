<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; align-items: flex-start;">
        <ui:VisualElement name="sanity-bar" style="flex-grow: 0; width: 20%; height: 5%; align-items: center; background-color: rgb(0, 0, 0); padding-top: 8px; padding-right: 8px; padding-bottom: 8px; padding-left: 8px; flex-direction: row; align-self: flex-start; justify-content: flex-start; align-content: center;">
            <ui:VisualElement name="sanity-bar-fill" style="flex-grow: 0; background-color: rgb(255, 0, 0); -unity-slice-scale: 1px; background-size: 100% 100%; width: 100%; height: 100%; align-self: flex-start; font-size: 8%;"/>
        </ui:VisualElement>
        <ui:Label text="00:00" name="timer" style="width: 47px; right: auto; top: auto; color: rgb(255, 255, 255);"/>
    </ui:VisualElement>
</ui:UXML>
