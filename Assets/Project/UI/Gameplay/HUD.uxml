<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; align-items: flex-start;">
        <ui:VisualElement name="sanity-bar" style="flex-grow: 0; width: 500px; height: 100px; align-items: stretch; background-color: rgb(0, 0, 0); padding-top: 8px; padding-right: 8px; padding-bottom: 8px; padding-left: 8px; flex-direction: row; align-self: flex-start;">
            <ui:VisualElement name="sanity-bar-fill" style="flex-grow: 0; background-color: rgb(255, 0, 0); -unity-slice-scale: 1px; background-size: 100% 100%; width: 100%; height: 100%; align-self: flex-start;"/>
            <ui:Label text="SANITY" style="-unity-text-align: middle-center; font-size: 12px; color: rgb(255, 255, 255); white-space: normal; width: 10px; -unity-font-style: bold; padding-top: 8px; padding-right: 8px; padding-bottom: 8px; padding-left: 8px; align-self: flex-end; align-content: center; justify-content: center; align-items: center; height: 100%;"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
